# ──────────────────────────────────────────────
# Vestara Admin Dashboard — Environment Variables
# ──────────────────────────────────────────────

NODE_ENV=development

# API
API_PORT=5000
API_HOST=localhost
API_URL=http://localhost:5000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vestara_admin

# Redis (optional, for caching & sessions)
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=replace-with-secure-secret
JWT_REFRESH_SECRET=replace-with-secure-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Frontend
VITE_API_URL=http://localhost:5000
VITE_APP_NAME=Vestara Admin

# SMTP (email notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@vestara.com

# File Storage
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1

# Logging
LOG_LEVEL=debug
